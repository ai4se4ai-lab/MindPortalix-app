# Supabase (publishable key replaces anon key in current Supabase projects)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# Server-side only. Required for trusted edge functions; never expose to the browser.
SUPABASE_SECRET_KEY=sb_secret_your-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# App
APP_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# Feature Flags
ENABLE_REVIEWER=true
ENABLE_MEMORY=true
ENABLE_PAID_MODELS=false
